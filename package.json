{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "node node_modules/hexo-cli/bin/hexo generate",
    "start": "node node_modules/hexo-cli/bin/hexo server --static",
    "clean": "node node_modules/hexo-cli/bin/hexo clean",
    "deploy": "git push origin main",
    "server": "node node_modules/hexo-cli/bin/hexo server --static",
    "server:watch": "node node_modules/hexo-cli/bin/hexo server",
    "build:deploy": "node node_modules/hexo-cli/bin/hexo clean && node node_modules/hexo-cli/bin/hexo generate && node tools/assemble-deploy.js",
    "vercel-build": "node node_modules/hexo-cli/bin/hexo clean && node node_modules/hexo-cli/bin/hexo generate"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "hexo": "^8.0.0",
    "hexo-abbrlink": "^2.2.1",
    "hexo-baidu-url-submit": "^0.0.6",
    "hexo-blog-encrypt": "^3.1.9",
    "hexo-butterfly-extjs": "^1.5.5",
    "hexo-filter-nofollow": "^2.0.2",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "^4.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-searchdb": "^1.5.0",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-hide-posts": "^0.4.3",
    "hexo-image-opt": "^1.1.6",
    "hexo-neat": "^1.0.9",
    "hexo-offline": "^4.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-butterfly": "^5.5.4",
    "hexo-wordcount": "^6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
